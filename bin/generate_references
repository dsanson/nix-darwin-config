#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# requirements: pandoc bibexport-json.lua jq

bib="${BIB:-$HOME/d/research/zotero.json}"
bibout="${BIBOUT:-references.json}"

args=()
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -o)
      bibout="$2"
      shift 2
      ;;
    -b)
      bib="$2"
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

echo BIBOUT="$bibout" pandoc "${args[@]}" --to bibexport-json.lua --bibliography "$bib"
BIBOUT="$bibout" pandoc "${args[@]}" --to bibexport-json.lua --bibliography "$bib"
